<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>人形机器人专利分析大屏</title>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Noto Sans SC', 'Microsoft YaHei', 'PingFang SC', sans-serif;
            background: linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #16213e 100%);
            color: #fff;
            min-height: 100vh;
            overflow-x: hidden;
        }
        
        .dashboard {
            padding: 20px;
            max-width: 1920px;
            margin: 0 auto;
        }
        
        .header {
            text-align: center;
            padding: 16px 0 24px;
            position: relative;
        }
        
        .header::before, .header::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 180px;
            height: 1px;
            background: linear-gradient(90deg, transparent, #667eea, transparent);
        }
        
        .header::before { left: 8%; }
        .header::after { right: 8%; }
        
        .header h1 {
            font-size: 28px;
            font-weight: 700;
            background: linear-gradient(90deg, #667eea, #764ba2, #f093fb);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            letter-spacing: 4px;
        }
        
        .header p {
            color: #8892b0;
            margin-top: 6px;
            font-size: 13px;
        }
        
        .main-grid {
            display: grid;
            grid-template-columns: 260px 1fr 260px;
            gap: 16px;
            margin-top: 16px;
        }
        
        .panel {
            background: linear-gradient(145deg, rgba(30, 35, 50, 0.95), rgba(20, 25, 40, 0.98));
            border: 1px solid rgba(102, 126, 234, 0.15);
            border-radius: 14px;
            padding: 16px;
            backdrop-filter: blur(10px);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3),
                        inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        
        .panel-title {
            font-size: 13px;
            color: #667eea;
            border-left: 3px solid #667eea;
            padding-left: 10px;
            margin-bottom: 12px;
            font-weight: 600;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .panel-title svg {
            width: 16px;
            height: 16px;
            opacity: 0.8;
        }
        
        .map-container {
            grid-column: 2;
            grid-row: 1 / 3;
            min-height: 600px;
            display: flex;
            flex-direction: column;
            background: rgba(30, 35, 50, 0.6);
            border: 1px solid rgba(102, 126, 234, 0.15);
            border-radius: 16px;
            padding: 15px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4),
                        0 0 60px rgba(102, 126, 234, 0.05) inset;
        }
        
        #china-map {
            flex: 1;
            min-height: 450px;
            height: 100%;
            position: relative;
            background: transparent;
            border-radius: 10px;
            box-shadow: inset 0 0 30px rgba(102, 126, 234, 0.1);
        }
        
        #china-map svg {
            display: block;
            overflow: visible;
        }
        
        .left-panel, .right-panel {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        
        .stat-card {
            background: linear-gradient(145deg, rgba(102, 126, 234, 0.12), rgba(118, 75, 162, 0.08));
            border: 1px solid rgba(102, 126, 234, 0.2);
            border-radius: 12px;
            padding: 18px;
            text-align: center;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3), 
                        inset 0 1px 0 rgba(255, 255, 255, 0.05);
        }
        
        .stat-card:hover {
            background: linear-gradient(145deg, rgba(102, 126, 234, 0.18), rgba(118, 75, 162, 0.12));
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.2), 
                        inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }
        
        .stat-value {
            font-size: 38px;
            font-weight: 700;
            background: linear-gradient(90deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .stat-label {
            color: #8892b0;
            font-size: 11px;
            margin-top: 6px;
            letter-spacing: 1px;
            text-transform: uppercase;
        }
        
        .stat-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 10px;
        }
        
        .stat-mini {
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
            padding: 10px;
            text-align: center;
        }
        
        .stat-mini .value {
            font-size: 18px;
            font-weight: 600;
            color: #a8b2d1;
        }
        
        .stat-mini .label {
            font-size: 10px;
            color: #646a80;
            margin-top: 4px;
        }
        
        .chart-container {
            height: 160px;
            position: relative;
        }
        
        .map-toolbar {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 12px;
        }
        
        .map-btn {
            background: rgba(102, 126, 234, 0.12);
            border: 1px solid rgba(102, 126, 234, 0.3);
            border-radius: 20px;
            padding: 8px 20px;
            color: #667eea;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 12px;
            font-weight: 500;
        }
        
        .map-btn:hover, .map-btn.active {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: #fff;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);
        }
        
        /* 悬浮框 - 可交互 */
        .province-tooltip {
            position: fixed;
            background: linear-gradient(145deg, rgba(25, 28, 45, 0.98), rgba(18, 20, 35, 0.99));
            border: 1px solid rgba(102, 126, 234, 0.4);
            border-radius: 14px;
            padding: 16px;
            width: 320px;
            max-height: 400px;
            overflow-y: auto;
            display: none;
            z-index: 1000;
            box-shadow: 0 16px 48px rgba(0, 0, 0, 0.6);
            backdrop-filter: blur(16px);
            pointer-events: auto;
        }
        
        .province-tooltip.visible {
            display: block;
        }
        
        .province-tooltip h3 {
            color: #667eea;
            margin-bottom: 12px;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
        }
        
        .patent-list {
            max-height: 280px;
            overflow-y: auto;
        }
        
        .patent-item {
            padding: 10px;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-bottom: 6px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid transparent;
        }
        
        .patent-item:hover {
            background: rgba(102, 126, 234, 0.15);
            border-color: rgba(102, 126, 234, 0.3);
            transform: translateX(4px);
        }
        
        .patent-item .public-number {
            color: #a8b2d1;
            font-size: 12px;
            font-weight: 600;
        }
        
        .patent-item .title {
            color: #8892b0;
            font-size: 12px;
            margin-top: 4px;
            line-height: 1.4;
        }
        
        /* 专利详情弹窗 */
        .patent-modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 2000;
            padding: 20px;
        }
        
        .patent-modal.active { display: flex; }
        
        .patent-detail {
            background: linear-gradient(145deg, #1a1a2e, #16213e);
            border: 1px solid rgba(102, 126, 234, 0.3);
            border-radius: 20px;
            width: 100%;
            max-width: 850px;
            max-height: 88vh;
            overflow-y: auto;
            padding: 28px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 40px rgba(102, 126, 234, 0.1);
        }
        
        .patent-detail-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid rgba(102, 126, 234, 0.2);
        }
        
        .patent-detail h2 {
            background: linear-gradient(90deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-size: 20px;
        }
        
        .close-btn {
            background: rgba(102, 126, 234, 0.1);
            border: none;
            color: #667eea;
            font-size: 28px;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 36px;
            height: 36px;
            line-height: 36px;
            border-radius: 50%;
        }
        
        .close-btn:hover { 
            background: rgba(102, 126, 234, 0.2);
            transform: rotate(90deg);
        }
        
        .patent-info-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 20px;
        }
        
        .info-item {
            background: rgba(102, 126, 234, 0.06);
            border: 1px solid rgba(102, 126, 234, 0.12);
            border-radius: 10px;
            padding: 14px;
        }
        
        .info-item label {
            color: #646a80;
            font-size: 10px;
            display: block;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .info-item span {
            color: #ccd6f6;
            font-size: 13px;
            word-break: break-all;
            line-height: 1.5;
        }
        
        .info-item.full { grid-column: 1 / -1; }
        
        /* 图例 - 渐变条 */
        .legend-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            margin-top: 12px;
        }
        
        .legend-gradient {
            width: 200px;
            height: 12px;
            border-radius: 6px;
            background: linear-gradient(90deg, #1a1a2e, #667eea, #764ba2, #f093fb);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
        }
        
        .legend-label {
            color: #646a80;
            font-size: 11px;
        }
        
        /* 加载 */
        .loading-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: #667eea;
        }
        
        .spinner {
            width: 36px;
            height: 36px;
            border: 3px solid rgba(102, 126, 234, 0.2);
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 10px;
        }
        
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .current-location {
            text-align: center;
            color: #a8b2d1;
            font-size: 13px;
            margin-bottom: 10px;
            padding: 8px 16px;
            background: rgba(102, 126, 234, 0.1);
            border-radius: 20px;
            display: inline-block;
            border: 1px solid rgba(102, 126, 234, 0.2);
        }
        
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: rgba(0, 0, 0, 0.2); }
        ::-webkit-scrollbar-thumb { background: #667eea; border-radius: 3px; }
        
        @media (max-width: 1400px) {
            .main-grid { grid-template-columns: 220px 1fr 220px; }
        }
        
        @media (max-width: 1100px) {
            .main-grid { grid-template-columns: 1fr; }
            .map-container { grid-column: 1; grid-row: auto; }
        }
    </style>
</head>
<body>
    <div class="dashboard">
        <div class="header">
            <h1>人形机器人专利分析大屏</h1>
            <p>人形机器人领域专利数据分析与可视化系统</p>
        </div>
        
        <div class="main-grid">
            <div class="left-panel">
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                        </svg>
                        数据概览
                    </div>
                    <div class="stat-card">
                        <div class="stat-value" id="total-patents">--</div>
                        <div class="stat-label">专利总数</div>
                        <div class="stat-grid">
                            <div class="stat-mini">
                                <div class="value" id="total-provinces">--</div>
                                <div class="label">省份数量</div>
                            </div>
                            <div class="stat-mini">
                                <div class="value" id="total-cities">--</div>
                                <div class="label">城市数量</div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 6v6l4 2"/>
                        </svg>
                        专利类型分布
                    </div>
                    <div class="chart-container" id="patent-type-chart"></div>
                </div>
                
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="3" width="18" height="18" rx="2"/>
                            <path d="M9 9h6v6H9z"/>
                        </svg>
                        法律状态分布
                    </div>
                    <div class="chart-container" id="legal-status-chart"></div>
                </div>
            </div>
            
            <div class="panel map-container">
                <div class="panel-title">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                    </svg>
                    中国专利热力分布
                </div>
                <div class="current-location" id="current-location" style="display:none;">当前位置: 全国</div>
                <div class="map-toolbar">
                    <button class="map-btn active" id="btn-china" onclick="showChinaView()">全国视图</button>
                    <button class="map-btn" id="btn-back" style="display:none;" onclick="goBack()">返回全国</button>
                </div>
                <div id="china-map">
                    <div class="loading-overlay" id="map-loading">
                        <div class="spinner"></div>
                        <div>地图加载中...</div>
                    </div>
                </div>
                <div class="legend-bar">
                    <span class="legend-label">低密度</span>
                    <div class="legend-gradient"></div>
                    <span class="legend-label">高密度</span>
                </div>
            </div>
            
            <div class="right-panel">
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                        </svg>
                        申请年份趋势
                    </div>
                    <div class="chart-container" id="year-trend-chart"></div>
                </div>
                
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
                        </svg>
                        IPC分类 Top 10
                    </div>
                    <div class="chart-container" id="ipc-chart"></div>
                </div>
                
                <div class="panel">
                    <div class="panel-title">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                            <polyline points="14 2 14 8 20 8"/>
                        </svg>
                        引用与同族统计
                    </div>
                    <div id="citation-stats" style="padding: 8px 0;"></div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 可交互的省份悬浮框 -->
    <div class="province-tooltip" id="province-tooltip">
        <h3>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
            </svg>
            <span id="tooltip-title">--</span>
        </h3>
        <div class="patent-list" id="tooltip-patents"></div>
    </div>
    
    <!-- 专利详情弹窗 -->
    <div class="patent-modal" id="patent-modal">
        <div class="patent-detail">
            <div class="patent-detail-header">
                <h2 id="modal-title">专利详情</h2>
                <button class="close-btn" onclick="closePatentModal()">&times;</button>
            </div>
            <div id="patent-content"></div>
        </div>
    </div>
    
    <script>
        const API_BASE = 'http://localhost:5000/api';
        
        let allProvinceData = [];
        let provinceData = [];
        let cityData = {};
        let currentView = 'china';
        let currentProvince = null;
        let tooltipTimeout = null;
        let chinaGeoData = null;
        let isTooltipHovered = false;
        let clickTimer = null;
        let lastClickTarget = null;
        
        // 渐变配色方案
        const COLORS = {
            primary: '#667eea',
            secondary: '#764ba2',
            accent: '#f093fb',
            text: '#ccd6f6',
            textMuted: '#8892b0',
            bgDark: '#1a1a2e',
            chartColors: ['#667eea', '#764ba2', '#f093fb', '#a8b2d1', '#64b5f6', '#81c784', '#ffb74d', '#ce93d8', '#4dd0e1', '#90a4ae']
        };
        
        document.addEventListener('DOMContentLoaded', async () => {
            await loadOverviewStats();
            await loadProvinceStats();
            await loadPatentTypeChart();
            await loadLegalStatusChart();
            await loadYearTrendChart();
            await loadIPCChart();
            await loadCitationStats();
            await initMap();
        });
        
        async function loadOverviewStats() {
            try {
                const response = await fetch(`${API_BASE}/stats/overview`);
                const data = await response.json();
                if (data.success) {
                    document.getElementById('total-patents').textContent = data.data.total_patents.toLocaleString();
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadProvinceStats() {
            try {
                const response = await fetch(`${API_BASE}/provinces`);
                const data = await response.json();
                if (data.success) {
                    allProvinceData = data.data;
                    provinceData = data.data;
                    document.getElementById('total-provinces').textContent = data.data.length;
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadPatentTypeChart() {
            try {
                const response = await fetch(`${API_BASE}/stats/patent-types`);
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    const container = document.getElementById('patent-type-chart');
                    container.innerHTML = '';
                    const width = container.clientWidth;
                    const height = 160;
                    
                    const svg = d3.select(container).append('svg').attr('width', width).attr('height', height);
                    const radius = Math.min(width, height) / 2 - 25;
                    const innerRadius = radius * 0.6;
                    
                    const g = svg.append('g').attr('transform', `translate(${width/2}, ${height/2 - 15})`);
                    const pie = d3.pie().value(d => d.count).sort(null);
                    const arc = d3.arc().innerRadius(innerRadius).outerRadius(radius);
                    
                    const arcs = g.selectAll('path')
                        .data(pie(data.data))
                        .enter()
                        .append('path')
                        .attr('d', arc)
                        .attr('fill', (d, i) => COLORS.chartColors[i % COLORS.chartColors.length])
                        .attr('stroke', '#0f0f1a')
                        .attr('stroke-width', 2);
                    
                    g.append('text').attr('text-anchor', 'middle').attr('dy', '-0.2em')
                        .attr('fill', COLORS.textMuted).attr('font-size', '10px').text('专利类型');
                    g.append('text').attr('text-anchor', 'middle').attr('dy', '1em')
                        .attr('fill', COLORS.primary).attr('font-size', '16px').attr('font-weight', 'bold')
                        .text(data.data.reduce((sum, d) => sum + d.count, 0));
                    
                    // 添加图例
                    const legend = svg.append('g').attr('transform', `translate(10, ${height - 35})`);
                    const legendItems = legend.selectAll('g').data(data.data).enter().append('g').attr('transform', (d, i) => `translate(${i * 55}, 0)`);
                    
                    legendItems.append('rect').attr('width', 10).attr('height', 10).attr('rx', 2)
                        .attr('fill', (d, i) => COLORS.chartColors[i % COLORS.chartColors.length]);
                    
                    legendItems.append('text').attr('x', 13).attr('y', 9)
                        .attr('fill', COLORS.textMuted).attr('font-size', '9px')
                        .text(d => d.patent_type ? d.patent_type.substring(0, 4) : '');
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadLegalStatusChart() {
            try {
                const response = await fetch(`${API_BASE}/stats/legal`);
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    const container = document.getElementById('legal-status-chart');
                    container.innerHTML = '';
                    const width = container.clientWidth;
                    const height = 160;
                    const margin = {top: 10, right: 10, bottom: 50, left: 10};
                    
                    const svg = d3.select(container).append('svg').attr('width', width).attr('height', height);
                    
                    const x = d3.scaleBand().domain(data.data.map(d => d.status)).range([margin.left, width - margin.right]).padding(0.3);
                    const y = d3.scaleLinear().domain([0, d3.max(data.data, d => d.count)]).range([height - margin.bottom, margin.top]);
                    
                    // 绘制柱状图
                    svg.selectAll('rect').data(data.data).enter().append('rect')
                        .attr('x', d => x(d.status))
                        .attr('y', d => y(d.count))
                        .attr('width', x.bandwidth())
                        .attr('height', d => height - margin.bottom - y(d.count))
                        .attr('fill', (d, i) => COLORS.chartColors[i % COLORS.chartColors.length])
                        .attr('rx', 4).attr('ry', 4);
                    
                    // 中文标签映射
                    const statusLabels = {
                        'Granted': '已授权',
                        'Examination': '审查中',
                        'Published': '已公开',
                        'Rejected': '已驳回',
                        'Withdrawn': '已撤回',
                        'Lapsed': '已失效',
                        'Other': '其他'
                    };
                    
                    // 绘制X轴标签 - 垂直排列
                    svg.append('g').attr('transform', `translate(0, ${height - margin.bottom})`)
                        .selectAll('text').data(data.data).enter().append('text')
                        .attr('x', d => x(d.status) + x.bandwidth() / 2)
                        .attr('y', 12)
                        .attr('text-anchor', 'middle')
                        .attr('fill', COLORS.textMuted)
                        .attr('font-size', '9px')
                        .text(d => statusLabels[d.status] || d.status);
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadYearTrendChart() {
            try {
                const response = await fetch(`${API_BASE}/stats/years`);
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    const container = document.getElementById('year-trend-chart');
                    container.innerHTML = '';
                    const width = container.clientWidth;
                    const height = 160;
                    const margin = {top: 15, right: 10, bottom: 25, left: 35};
                    
                    const svg = d3.select(container).append('svg').attr('width', width).attr('height', height);
                    
                    const x = d3.scaleLinear().domain(d3.extent(data.data, d => d.year)).range([margin.left, width - margin.right]);
                    const y = d3.scaleLinear().domain([0, d3.max(data.data, d => d.count)]).range([height - margin.bottom, margin.top]);
                    
                    const line = d3.line().x(d => x(d.year)).y(d => y(d.count)).curve(d3.curveMonotoneX);
                    svg.append('path').datum(data.data).attr('fill', 'none').attr('stroke', COLORS.primary)
                        .attr('stroke-width', 2.5).attr('d', line);
                    
                    svg.selectAll('circle').data(data.data).enter().append('circle')
                        .attr('cx', d => x(d.year)).attr('cy', d => y(d.count))
                        .attr('r', 4).attr('fill', COLORS.secondary).attr('stroke', '#0f0f1a').attr('stroke-width', 2);
                    
                    svg.append('g').attr('transform', `translate(0, ${height - margin.bottom})`)
                        .call(d3.axisBottom(x).tickFormat(d3.format('d')).ticks(5))
                        .selectAll('text').attr('fill', COLORS.textMuted);
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadIPCChart() {
            try {
                const response = await fetch(`${API_BASE}/stats/ipc?limit=10`);
                const data = await response.json();
                if (data.success && data.data.length > 0) {
                    const container = document.getElementById('ipc-chart');
                    container.innerHTML = '';
                    const width = container.clientWidth;
                    const height = 160;
                    const margin = {top: 5, right: 40, bottom: 5, left: 50};
                    
                    const svg = d3.select(container).append('svg').attr('width', width).attr('height', height);
                    
                    const y = d3.scaleBand().domain(data.data.map(d => d.ipc_subclass)).range([margin.top, height - margin.bottom]).padding(0.3);
                    const x = d3.scaleLinear().domain([0, d3.max(data.data, d => d.count)]).range([margin.left, width - margin.right]);
                    
                    data.data.forEach((d, i) => {
                        const color = COLORS.chartColors[i % COLORS.chartColors.length];
                        svg.append('rect').attr('y', y(d.ipc_subclass)).attr('height', y.bandwidth())
                            .attr('x', margin.left).attr('width', x(d.count) - margin.left)
                            .attr('fill', color).attr('rx', 3);
                        
                        svg.append('text').attr('x', margin.left - 5).attr('y', y(d.ipc_subclass) + y.bandwidth() / 2)
                            .attr('dy', '0.35em').attr('text-anchor', 'end').attr('fill', COLORS.textMuted).attr('font-size', '10px')
                            .text(d.ipc_subclass);
                        
                        svg.append('text').attr('x', x(d.count) + 5).attr('y', y(d.ipc_subclass) + y.bandwidth() / 2)
                            .attr('dy', '0.35em').attr('fill', color).attr('font-size', '10px').attr('font-weight', '600')
                            .text(d.count);
                    });
                }
            } catch (e) { console.error(e); }
        }
        
        async function loadCitationStats() {
            try {
                const response = await fetch(`${API_BASE}/stats/citations`);
                const data = await response.json();
                if (data.success) {
                    const s = data.data;
                    document.getElementById('citation-stats').innerHTML = `
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                            <div style="background:rgba(102,126,234,0.1);padding:10px;border-radius:8px;text-align:center;">
                                <div style="color:${COLORS.primary};font-size:18px;font-weight:bold;">${s.citations_5yr.mean.toFixed(1)}</div>
                                <div style="color:#646a80;font-size:10px;">5年引用均值</div>
                            </div>
                            <div style="background:rgba(118,75,162,0.1);padding:10px;border-radius:8px;text-align:center;">
                                <div style="color:${COLORS.secondary};font-size:18px;font-weight:bold;">${s.citations_3yr.mean.toFixed(1)}</div>
                                <div style="color:#646a80;font-size:10px;">3年引用均值</div>
                            </div>
                            <div style="background:rgba(240,147,251,0.1);padding:10px;border-radius:8px;text-align:center;">
                                <div style="color:${COLORS.accent};font-size:18px;font-weight:bold;">${s.family_count.mean.toFixed(1)}</div>
                                <div style="color:#646a80;font-size:10px;">同族专利均值</div>
                            </div>
                            <div style="background:rgba(168,178,209,0.1);padding:10px;border-radius:8px;text-align:center;">
                                <div style="color:${COLORS.text};font-size:18px;font-weight:bold;">${s.citations_5yr.max}</div>
                                <div style="color:#646a80;font-size:10px;">最高引用</div>
                            </div>
                        </div>
                    `;
                }
            } catch (e) { console.error(e); }
        }
        
        async function initMap() {
            const container = document.getElementById('china-map');
            const loading = document.getElementById('map-loading');
            chinaGeoData = null;
            window.chinaGeoData = null;
            
            try {
                // 从后端API获取高德地图数据
                const response = await fetch(`${API_BASE}/map/geojson`);
                const result = await response.json();
                
                if (result.success && result.data && result.data.features && result.data.features.length > 0) {
                    chinaGeoData = result.data;
                    window.chinaGeoData = result.data;
                    console.log('GeoJSON loaded, features:', result.data.features.length);
                    console.log('Sample feature:', result.data.features[0]);
                    loading.style.display = 'none';
                    drawMap('china');
                } else {
                    throw new Error(result.message || 'Invalid GeoJSON data');
                }
            } catch (e) {
                console.error('Map load failed:', e);
                loading.innerHTML = '<div style="color:#667eea;text-align:center;padding:20px;">地图加载失败<br><small>' + e.message + '</small></div>';
            }
        }
        
        function drawMap(viewType) {
            const container = document.getElementById('china-map');
            container.innerHTML = '';
            
            const width = container.clientWidth || 600;
            const height = container.clientHeight || 500;
            
            console.log('Container size:', width, 'x', height);
            
            const svg = d3.select(container).append('svg')
                .attr('width', width)
                .attr('height', height)
                .attr('viewBox', '0 0 ' + width + ' ' + height);
            
            const geoData = chinaGeoData;
            if (!geoData || !geoData.features || geoData.features.length === 0) {
                svg.append('text').attr('x', width/2).attr('y', height/2)
                    .attr('text-anchor', 'middle').attr('fill', '#667eea')
                    .text('地图数据加载失败');
                return;
            }
            
            console.log('Drawing map with', geoData.features.length, 'features');
            
            const features = geoData.features;
            
            // 创建投影 - 使用适合中国地图的参数
            const projection = d3.geoMercator()
                .center([105, 35])  // 中国地理中心
                .scale(width / 5.0)
                .translate([width / 2, height / 2]);
            
            const pathGenerator = d3.geoPath().projection(projection);
            
            // 渐变色比例尺
            const maxCount = Math.max(...provinceData.map(d => d.patent_count || d.count || 0), 1);
            const colorScale = d3.scaleSequential(d3.interpolatePurples).domain([0, maxCount]);
            
            // 创建省份名称到专利数据的映射
            const provinceMap = {};
            provinceData.forEach(p => {
                const key = normalizeName(p.province_name || '');
                provinceMap[key] = p;
            });
            
            // 绘制地图
            const g = svg.append('g');
            
            // 测试第一个路径
            const testPath = pathGenerator(features[0]);
            console.log('Test path:', testPath ? testPath.substring(0, 100) : 'null');
            
            g.selectAll('path')
                .data(features)
                .enter()
                .append('path')
                .attr('d', pathGenerator)
                .attr('fill', d => {
                    const name = d.properties ? (d.properties.name || '') : '';
                    const key = normalizeName(name);
                    const data = provinceMap[key];
                    const count = data ? (data.patent_count || data.count || 0) : 0;
                    return count > 0 ? colorScale(count) : '#5a5a7a';
                })
                .attr('stroke', '#3a3a5a')
                .attr('stroke-width', 1)
                .style('cursor', 'pointer')
                .on('mouseenter', function(event, d) {
                    d3.select(this).attr('stroke', '#667eea').attr('stroke-width', 2);
                    showProvinceTooltip(event, d.properties?.name || '', 'china');
                })
                .on('mouseleave', function() {
                    d3.select(this).attr('stroke', '#3a3a5a').attr('stroke-width', 1);
                });
            
            // 添加专利数量标签
            g.selectAll('text')
                .data(features)
                .enter()
                .append('text')
                .attr('transform', d => {
                    const centroid = pathGenerator.centroid(d);
                    return `translate(${centroid[0]}, ${centroid[1]})`;
                })
                .attr('text-anchor', 'middle')
                .attr('fill', 'white')
                .attr('font-size', '10px')
                .attr('pointer-events', 'none')
                .text(d => {
                    const name = d.properties ? (d.properties.name || '') : '';
                    const key = normalizeName(name);
                    const data = provinceMap[key];
                    return data ? (data.patent_count || 0) : '';
                });
            
            console.log('Map drawn with', features.length, 'paths');
        }
        
        function handleMapClick(event, name, viewType) {
            if (clickTimer && lastClickTarget === event.target) {
                clearTimeout(clickTimer);
                clickTimer = null;
                if (viewType === 'china') {
                    selectProvince(name);
                }
            } else {
                lastClickTarget = event.target;
                clickTimer = setTimeout(() => {
                    clickTimer = null;
                }, 300);
            }
        }
        
        function normalizeName(name) {
            if (!name) return '';
            // 处理 "北京市" -> "北京", "内蒙古自治区" -> "内蒙古" 等
            return name.replace(/省|市|自治区|回族自治区|壮族自治区|维吾尔自治区|特别行政区/g, '').trim();
        }
        
        function getProvinceInfo(name) {
            const centers = {
                '北京': { center: [116.4, 39.9] }, '天津': { center: [117.2, 39.1] },
                '河北': { center: [115, 38] }, '山西': { center: [112, 37.5] },
                '内蒙古': { center: [112, 42] }, '辽宁': { center: [123, 41.5] },
                '吉林': { center: [126, 43] }, '黑龙江': { center: [128, 47] },
                '上海': { center: [121.5, 31.2] }, '江苏': { center: [119, 33] },
                '浙江': { center: [120, 29.5] }, '安徽': { center: [117, 31.8] },
                '福建': { center: [118, 26] }, '江西': { center: [116, 28] },
                '山东': { center: [118, 36] }, '河南': { center: [113, 34] },
                '湖北': { center: [112.5, 31] }, '湖南': { center: [112, 28] },
                '广东': { center: [113.5, 23] }, '广西': { center: [108, 24] },
                '海南': { center: [110, 19.5] }, '重庆': { center: [107.5, 29.5] },
                '四川': { center: [104, 30.5] }, '贵州': { center: [106.5, 26.5] },
                '云南': { center: [102, 25] }, '西藏': { center: [88, 32] },
                '陕西': { center: [108.5, 34] }, '甘肃': { center: [104, 37] },
                '青海': { center: [96, 36] }, '宁夏': { center: [106, 38] },
                '新疆': { center: [85, 42] }, '台湾': { center: [121, 24] },
                '香港': { center: [114.2, 22.3] }, '澳门': { center: [113.5, 22.2] }
            };
            return centers[name] || { center: [105, 36] };
        }
        
        function getProvinceLabels() {
            return [
                { name: '北京', coords: [116.4, 39.9] }, { name: '广东', coords: [113, 23] },
                { name: '江苏', coords: [120, 33] }, { name: '浙江', coords: [120, 29] },
                { name: '山东', coords: [118, 36] }, { name: '河南', coords: [113, 34] },
                { name: '四川', coords: [104, 30] }, { name: '湖北', coords: [112, 31] },
                { name: '安徽', coords: [117, 32] }, { name: '湖南', coords: [112, 28] },
                { name: '福建', coords: [119, 26] }, { name: '上海', coords: [121.5, 31.2] },
                { name: '重庆', coords: [107, 29] }, { name: '陕西', coords: [108, 34] },
                { name: '辽宁', coords: [123, 41] }, { name: '河北', coords: [115, 38] },
                { name: '江西', coords: [116, 28] }, { name: '天津', coords: [117.2, 39.1] },
                { name: '云南', coords: [102, 25] }, { name: '贵州', coords: [106, 27] }
            ];
        }
        
        function getCityLabels() {
            if (!cityData[currentProvince]) return [];
            return cityData[currentProvince]
                .filter(c => c.latitude && c.longitude)
                .slice(0, 15)
                .map(c => ({ name: c.city_name, coords: [parseFloat(c.longitude), parseFloat(c.latitude)] }));
        }
        
        function showProvinceTooltip(event, name, viewType) {
            const tooltip = document.getElementById('province-tooltip');
            let data;
            
            if (viewType === 'china') {
                data = provinceData.find(p => normalizeName(p.province_name) === normalizeName(name));
                if (!data) data = provinceData.find(p => p.province_name?.includes(name));
            } else {
                data = cityData[currentProvince]?.find(c => normalizeName(c.city_name) === normalizeName(name));
            }
            
            const count = data ? (data.patent_count || data.count || 0) : 0;
            const label = viewType === 'china' ? (data?.province_name || name) : (data?.city_name || name);
            
            if (count === 0) {
                tooltip.classList.remove('visible');
                return;
            }
            
            document.getElementById('tooltip-title').textContent = `${label} (${count}项专利)`;
            
            // 加载专利列表
            const apiPath = viewType === 'china' 
                ? `${API_BASE}/patents/province/${encodeURIComponent(label)}?page_size=50`
                : `${API_BASE}/patents/city/${encodeURIComponent(currentProvince)}/${encodeURIComponent(label)}?page_size=50`;
            
            fetch(apiPath)
                .then(r => r.json())
                .then(result => {
                    if (result.success) {
                        const patentsHtml = result.data.map(p => `
                            <div class="patent-item" onclick="showPatentDetail('${p.public_number}')">
                                <div class="public-number">${p.public_number}</div>
                                <div class="title">${p.title || ''}</div>
                            </div>
                        `).join('') || '<div style="color:#646a80;padding:10px;">暂无数据</div>';
                        document.getElementById('tooltip-patents').innerHTML = patentsHtml;
                    }
                })
                .catch(e => console.error(e));
            
            // 定位悬浮框
            tooltip.classList.add('visible');
            positionTooltip(event);
            
            // 处理鼠标进入悬浮框
            tooltip.onmouseenter = () => { isTooltipHovered = true; };
            tooltip.onmouseleave = () => { 
                isTooltipHovered = false; 
                tooltip.classList.remove('visible');
            };
        }
        
        function positionTooltip(event) {
            const tooltip = document.getElementById('province-tooltip');
            let x = event.pageX + 15;
            let y = event.pageY + 15;
            
            if (x + 340 > window.innerWidth) x = event.pageX - 335;
            if (y + 420 > window.innerHeight) y = event.pageY - 420;
            
            tooltip.style.left = x + 'px';
            tooltip.style.top = y + 'px';
        }
        
        function hideProvinceTooltip() {
            setTimeout(() => {
                if (!isTooltipHovered) {
                    document.getElementById('province-tooltip').classList.remove('visible');
                }
            }, 100);
        }
        
        async function selectProvince(provinceName) {
            const provinceCities = await loadCities(provinceName);
            if (provinceCities && provinceCities.length > 0) {
                currentProvince = provinceName;
                provinceData = provinceCities.map(c => ({
                    city_name: c.city_name,
                    count: c.patent_count,
                    latitude: c.latitude,
                    longitude: c.longitude
                }));
                currentView = 'province';
                document.getElementById('current-location').style.display = 'inline-block';
                document.getElementById('current-location').textContent = `当前位置: ${provinceName}`;
                document.getElementById('btn-china').classList.remove('active');
                document.getElementById('btn-back').style.display = 'inline-block';
                document.getElementById('btn-back').classList.add('active');
                drawMap('province');
            }
        }
        
        async function loadCities(province) {
            try {
                const response = await fetch(`${API_BASE}/cities/${encodeURIComponent(province)}`);
                const data = await response.json();
                if (data.success) {
                    cityData[province] = data.data;
                    return data.data;
                }
            } catch (e) { console.error(e); }
            return [];
        }
        
        function showChinaView() {
            currentView = 'china';
            currentProvince = null;
            provinceData = allProvinceData;
            document.getElementById('current-location').style.display = 'none';
            document.getElementById('btn-china').classList.add('active');
            document.getElementById('btn-back').style.display = 'none';
            document.getElementById('btn-back').classList.remove('active');
            drawMap('china');
        }
        
        function goBack() {
            showChinaView();
        }
        
        async function showPatentDetail(publicNumber) {
            document.getElementById('province-tooltip').classList.remove('visible');
            
            try {
                const response = await fetch(`${API_BASE}/patent/${publicNumber}`);
                const result = await response.json();
                
                if (result.success) {
                    const p = result.data;
                    document.getElementById('modal-title').textContent = p.public_number;
                    document.getElementById('patent-content').innerHTML = `
                        <div class="patent-info-grid">
                            <div class="info-item full">
                                <label>标题</label>
                                <span>${p.title || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>申请人</label>
                                <span>${p.original_applicant || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>申请日期</label>
                                <span>${p.application_date || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>专利类型</label>
                                <span style="color:${COLORS.primary};font-weight:600;">${p.patent_type || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>法律状态</label>
                                <span style="color:${COLORS.secondary};">${p.legal_status || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>IPC分类</label>
                                <span>${p.ipc_subclass || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>被引用次数(5年)</label>
                                <span style="color:${COLORS.accent};font-weight:600;">${p.citations_5yr || 0}</span>
                            </div>
                            <div class="info-item">
                                <label>同族专利数</label>
                                <span>${p.family_count || 1}</span>
                            </div>
                            <div class="info-item full">
                                <label>摘要</label>
                                <span>${p.abstract || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>所在省份</label>
                                <span>${p.applicant_province || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>所在城市</label>
                                <span>${p.applicant_city || ''}</span>
                            </div>
                            <div class="info-item">
                                <label>受理局</label>
                                <span>${p.receiving_office || ''}</span>
                            </div>
                        </div>
                    `;
                    document.getElementById('patent-modal').classList.add('active');
                }
            } catch (e) { console.error(e); }
        }
        
        function closePatentModal() {
            document.getElementById('patent-modal').classList.remove('active');
        }
        
        // 点击空白处关闭弹窗
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('patent-modal')) {
                closePatentModal();
            }
        });
    </script>
</body>
</html>